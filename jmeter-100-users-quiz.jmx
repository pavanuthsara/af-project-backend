                <stringProp name="Argument.value">{&#xd;
  &quot;title&quot;: &quot;Plastic Sorting 101 - Load Test&quot;,&#xd;
  &quot;description&quot;: &quot;Learn to identify and sort different plastic types correctly&quot;,&#xd;
  &quot;difficulty&quot;: &quot;Beginner&quot;,&#xd;
  &quot;passingScore&quot;: 60&#xd;
